          <a class="uiPill" href="https://github.com/beverlypillzz-collab/Vodkinnet-RT" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </div>
    <div class="topActions">
      <div class="vpnCard">
          <a class="uiPill brandLink" href="https://vodkin.net" target="_blank" rel="noopener noreferrer">
            <span class="brandDot"></span>
            <span>VodkinNET</span>
          </a>
      </div>
      <div class="returnCard">
        <a class="uiPill backBtn" href="/cgi-bin/luci/admin/services">Вернуться в службы OpenWrt</a>
      </div>
    </div>
  </section>

  <section class="grid">
    <div class="panel">
      <h2>Состояние</h2>
      <div class="metrics">
EOF
	metric "Сервис procd" "$service_state" "$service_tone"
	metric "Xray туннель" "$xray_state" "$xray_tone"
	if [ -n "$hub_url" ]; then
		metric "Hub URL" "настроен" "linkMetric"
	else
		metric "Hub URL" "не задан" "linkMetric"
	fi
	cat <<EOF
      </div>
      <form method="post" class="actions">
        <input type="hidden" name="key" value="$(h "$key")">
        <button class="btn" name="action" value="start">Запустить</button>
        <button class="btn" name="action" value="restart">Перезапустить</button>
        <button class="btn" name="action" value="stop">Остановить</button>
        <button class="btn" name="action" value="heartbeat">Heartbeat</button>
        <button class="btn" name="action" value="doctor">Проверка</button>
        <button class="btn" name="action" value="install_xray_tmp">Поставить Xray в /tmp</button>
        <a class="btn" href="?key=$(h "$key")&action=download_config">Скачать Xray config</a>
        <button class="btn" name="action" value="show_xray_settings">Xray настройки</button>
      </form>
EOF
	if [ -n "$RESULT_TITLE" ]; then
		printf '<div class="notice %s"><strong>%s</strong>\n%s</div>' "$(h "$RESULT_KIND")" "$(h "$RESULT_TITLE")" "$(h "$RESULT_BODY")"
	fi
	if [ "$SHOW_XRAY_SETTINGS" = "1" ]; then
		cat <<EOF
      <div class="xrayApply">
        <h3>Xray настройки</h3>
        <p class="helperText">Вставь сюда блок команд из OpenWrt config на VPS. Роутер сам применит UCI, пересоберет Xray config, включит сервис и отправит heartbeat.</p>
        <form method="post">
          <input type="hidden" name="key" value="$(h "$key")">
          <textarea class="scriptBox" name="xray_settings_script" spellcheck="false" placeholder="uci -q delete owrtremote.main
uci set owrtremote.main=remote
uci set owrtremote.main.enabled='1'
...
owrt-remote heartbeat"></textarea>
          <div class="actions">
            <button class="btn good" name="action" value="apply_xray_settings">Применить настройки</button>
            <button class="btn" name="action" value="show_xray_settings">Очистить поле</button>
          </div>
        </form>
      </div>
EOF
	fi
	cat <<EOF
    </div>
  </section>

  <section class="panel" style="margin-top:16px">
    <div class="panelHead">
      <h2>Настройки роутера</h2>
      <form method="post" class="headActionForm">
        <input type="hidden" name="key" value="$(h "$key")">
        <button class="btn clearBtn" name="action" value="clear_config">Очистить Конфигурацию</button>
      </form>
    </div>
    <form method="post">
      <input type="hidden" name="key" value="$(h "$key")">
      <label class="check"><input type="checkbox" name="enabled" value="1" $enabled_checked> Включить агент и автозапуск</label>
      <div class="formgrid">
EOF
	field router_id "Router ID" text "Уникальное имя этого роутера в VPS-панели. Бери из карточки роутера на VPS: main, office-1, shop-2."
	field router_name "Название" text "Красивое имя для карточки на VPS. Можно писать по-русски: Главный роутер, Дом, Офис."
	field role "Роль" text "main ставь для главного роутера. node ставь для дополнительных роутеров, которые просто цепляешь и мониторишь."
	field public_url "Public URL" text "Обычно оставь пустым. Нужно только если у роутера уже есть своя готовая публичная ссылка."
	field hub_url "Hub URL" password "Адрес веб-панели на VPS, куда роутер отправляет online/offline. Бери из VPS, например http://VPS_IP:8088."
	field hub_token "Hub token" password "Секрет AGENT_TOKEN из VPS-хаба. Его показывает команда init/serve на VPS; нужен для heartbeat."
	field heartbeat_interval "Heartbeat, секунд" number "Как часто роутер сообщает VPS, что он online. Обычно 30 секунд, меньше 10 не ставь."
	field xray_bin "Xray binary" text "Путь к Xray на роутере. Если ставил пакет xray-core, обычно оставь /usr/bin/xray."
	field xray_config "Xray config" text "Куда агент сохранит клиентский Xray-конфиг. Обычно оставь /etc/xray/owrt-remote-client.json."
	field vps_host "VPS host" password "IP или домен VPS, куда Xray роутера подключается reverse-туннелем. Бери IP/домен своего VPS."
	field vps_port "VPS Xray port" number "Порт Xray на VPS для reverse-туннеля. Должен совпадать с render-xray на VPS, обычно 8443."
	field vless_uuid "VLESS UUID" password "Уникальный UUID роутера. Бери из карточки роутера на VPS или из команды print-openwrt-config."
	field vless_encryption "VLESS encryption" text "Для этой схемы оставь none. Меняй только если сам меняешь Xray-конфиг на VPS."
	field vless_flow "VLESS flow" text "Обычно оставь пустым. Нужно только для специальных режимов Xray."
	field reverse_tag "Reverse tag" text "Метка reverse-туннеля внутри Xray. Обычно оставь reverse-in, если на VPS не задавал другое."
	field ssh_vless_uuid "SSH VLESS UUID" password "UUID отдельного SSH reverse-туннеля. Бери из OpenWrt config на VPS для этого роутера."
	field ssh_reverse_tag "SSH reverse tag" text "Метка reverse-туннеля для SSH. Обычно reverse-in-ssh."
	field admin_host "Admin host" text "Куда внутри роутера вести админку LuCI. Обычно 127.0.0.1, потому что uhttpd слушает локально."
	field admin_port "Admin port" number "Порт LuCI/uhttpd внутри роутера. Обычно 80; если LuCI на другом порту, укажи его."
	field ssh_host "SSH host" text "Куда внутри роутера вести SSH. Обычно 127.0.0.1."
	field ssh_port "SSH port" number "Порт Dropbear/SSH внутри роутера. Обычно 22."
	cat <<EOF
      </div>
      <div class="actions saveActions">
        <button class="btn primary" name="action" value="save">Сохранить</button>
        <button class="btn good" name="action" value="save_start">Сохранить и запустить</button>
      </div>
    </form>
  </section>
</main>
</body>
</html>
EOF
}

read_request

if ! authorized; then
	render_unauthorized
	exit 0
fi

action="$(param action)"

if [ "$action" = "download_config" ]; then
	http_json
	"$AGENT" render-client --stdout 2>&1
	exit 0
fi

if [ "${REQUEST_METHOD:-GET}" = "POST" ]; then
	case "$action" in
		save)
			save_config
			;;
		save_start)
			save_config
			run_action start
			;;
		show_xray_settings)
			SHOW_XRAY_SETTINGS="1"
			;;
		apply_xray_settings)
			apply_xray_settings
			;;
		clear_config)
			clear_config
			;;
		start|stop|restart|heartbeat|doctor|install_xray_tmp)
			run_action "$action"
			;;
	esac
fi

render_page
