#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

uci_get() {
	local key default value
	key="$1"
	default="$2"
	value="$(uci -q get "owrtremote.main.$key" 2>/dev/null || true)"
	[ -n "$value" ] && {
		printf '%s' "$value"
		return
	}
	printf '%s' "$default"
}

config_enabled() {
	case "$(uci_get enabled 0)" in
		1|yes|true|on|enabled) return 0 ;;
		*) return 1 ;;
	esac
}

xray_pids() {
	local config cmdline cmd pid
	config="$(uci_get xray_config /etc/xray/owrt-remote-client.json)"
	[ -n "$config" ] || return 0
	for cmdline in /proc/[0-9]*/cmdline; do
		[ -r "$cmdline" ] || continue
		cmd="$(tr '\000' ' ' <"$cmdline" 2>/dev/null || true)"
		case "$cmd" in
			*xray*"$config"*|*xray-core*"$config"*)
				pid="${cmdline%/cmdline}"
				pid="${pid##*/}"
				printf '%s\n' "$pid"
				;;
		esac
	done
}

stop_xray_processes() {
	local pids pid
	pids="$(xray_pids)"
	for pid in $pids; do
		kill "$pid" >/dev/null 2>&1 || true
	done
	sleep 1
	for pid in $pids; do
		kill -0 "$pid" >/dev/null 2>&1 && kill -9 "$pid" >/dev/null 2>&1 || true
	done
}

start_service() {
	mkdir -p /var/lock /var/run /tmp/owrt-xray

	if ! config_enabled; then
		echo "owrt-remote disabled in /etc/config/owrtremote"
		return 0
	fi

	procd_open_instance xray
	procd_set_param command /usr/sbin/owrt-remote run
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	procd_open_instance heartbeat
	procd_set_param command /usr/sbin/owrt-remote heartbeat-loop
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

stop_service() {
	stop_xray_processes
}

service_triggers() {
	procd_add_reload_trigger owrtremote
}
